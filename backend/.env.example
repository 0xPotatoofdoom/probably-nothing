# Probably Nothing — canonical backend env reference.
# Copy to backend/.env or export before `docker compose up`.

# LLM adapter ------------------------------------------------------------------
# backend: mock | ollama | openai
PN_LLM_BACKEND=ollama
PN_LLM_MODEL=qwen3-coder-next:latest
# For ollama running on the DGX host (reached via the compose overlay):
PN_LLM_ENDPOINT=http://host.docker.internal:11434
# For OpenAI-compatible servers (vLLM / TGI / LM Studio / OpenAI):
# PN_LLM_ENDPOINT=http://localhost:8080/v1
# PN_LLM_API_KEY=

# Autoresearch loop ------------------------------------------------------------
# Wall-clock budget per analyze() call (seconds). With real Foundry + LLM-authored
# scenarios, sensible values are 1800 (30 min) — 43200 (12 hr).
PN_WALL_BUDGET=1800
# Max concurrent variant evaluations.
PN_MAX_CONCURRENCY=12

# Scenario generation ----------------------------------------------------------
# Foundry workspace Docker image (built from backend/foundry_workspace/Dockerfile).
PN_FOUNDRY_IMAGE=probably-nothing-foundry
# Scenarios proposed at run start (before gen 1).
PN_SEED_SCENARIOS=20
# Scenarios proposed at the end of every generation.
PN_PER_GEN_SCENARIOS=8
# Cap on active scenarios. Low-informativeness ones are pruned above this.
PN_MAX_SCENARIOS=128
# Per-variant forge test timeout (seconds).
PN_FORGE_TIMEOUT=180
# Per-scenario compile-gate timeout (seconds).
PN_COMPILE_TIMEOUT=60
# Vault output directory (overridden by CLI --output).
PN_VAULT_DIR=/tmp/probably-nothing-vaults
